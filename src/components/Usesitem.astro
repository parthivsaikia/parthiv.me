---
export interface Props {
  name: string;
  configUrl?: string;
}

const { name, configUrl } = Astro.props;
---

<div
  class="flex items-baseline justify-between py-4 border-b border-zinc-800 last:border-none"
>
  <span class="text-[15px] text-zinc-200">{name}</span>
  {
    configUrl && (
      <a
        href={configUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-xs text-zinc-600 underline underline-offset-[3px] decoration-zinc-700 hover:text-zinc-300 hover:decoration-zinc-400 transition-colors duration-150"
      >
        config ↗
      </a>
    )
  }
</div>
