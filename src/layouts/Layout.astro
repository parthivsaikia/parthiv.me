---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <title>Parthiv Saikia</title>

    <meta
      name="description"
      content="Parthiv Saikia builds backend systems, terminal interfaces, and local-first software using Go and Zig."
    />

    <link rel="canonical" href="https://parthiv.me/" />

    <!-- Open Graph -->
    <meta property="og:title" content="Parthiv Saikia" />
    <meta
      property="og:description"
      content="Backend systems, TUIs, and local-first software."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://parthiv.me/" />
    <meta property="og:image" content="https://parthiv.me/og.png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Parthiv Saikia" />
    <meta
      name="twitter:description"
      content="Backend systems, TUIs, and local-first software."
    />
    <meta name="twitter:image" content="https://parthiv.me/og.png" />

    <link rel="icon" href="/favicon.svg" />
  </head>

  <body class="min-h-screen flex flex-col">
    <section class="flex flex-1 mx-auto p-12 gap-8 flex-col md:w-3xl">
      <div class="flex justify-end">
        <Navbar />
      </div>

      <main class="flex-1 flex flex-col gap-16 text-[16px]">
        <slot />
      </main>

      <Footer />
    </section>
  </body>
</html>
