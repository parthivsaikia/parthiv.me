---
import "../styles/global.css";
import Baselayout from "../layouts/Layout.astro";

interface Props {
  title: string;
  date: Date;
  description?: string;
}

const { title, date, description } = Astro.props;

const formatted = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Baselayout>
  <article class="flex flex-col gap-10 text-zinc-300">
    <div class="flex flex-col gap-4">
      <a
        href="/blogs"
        class="text-xs text-zinc-600 uppercase tracking-widest hover:text-zinc-400 transition-colors duration-150 w-fit"
      >
        ← Writing
      </a>
      <div class="flex flex-col gap-2">
        <h1
          class="text-xl font-medium tracking-tight text-zinc-100 leading-snug"
        >
          {title}
        </h1>
        <span class="text-sm text-zinc-600">{formatted}</span>
      </div>
      {
        description && (
          <p class="text-[15px] text-zinc-500 leading-7 border-l border-zinc-800 pl-4">
            {description}
          </p>
        )
      }
    </div>

    <!-- Prose body: Tailwind Typography via @tailwindcss/typography -->
    <!-- Add `prose prose-invert prose-zinc` if you install the plugin -->
    <!-- Otherwise the slot renders your MDX/Markdown as-is -->
    <div class="prose prose-invert prose-zinc text-[15px] leading-8">
      <slot />
    </div>
  </article>
</Baselayout>
